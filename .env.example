# Copy this file to .env and fill in your values
# .env is gitignored and must never be committed

# JWT
JWT_SECRET=change_me_to_a_long_random_string

# PostgreSQL
DB_USER=secret_adm
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secret_share

# Redis
REDIS_URL=redis://localhost:6379

# Tests (same as above or a separate test DB)
TEST_DB_USER=secret_adm
TEST_DB_PASSWORD=your_db_password_here
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=secret_share
TEST_REDIS_URL=redis://localhost:6379

# OCI Email Delivery (SMTP)
SMTP_HOST=smtp.email.us-ashburn-1.oci.oraclecloud.com
SMTP_PORT=587
SMTP_USER=ocid1.user.oc1..example@ocid1.tenancy.oc1..example.xy.com
SMTP_PASS=your_generated_smtp_password
SMTP_FROM=no-reply@yourdomain.com

# Cloudflare Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token
